rules_version = '2';

/* ============================================================
   ClearSky-OMEGA · Financing Partners Portal
   Storage security rules
   ------------------------------------------------------------
   Project documents live under:  projects/{projectId}/{fileName}

   NOTE: Storage rules can't read Firestore, so fine-grained
   "only this project's developer" checks aren't possible here
   without Cloud Functions. The pragmatic model below:
     - any signed-in user may READ a project file (download URLs
       are already unguessable tokens; access to the URL is gated
       by the app, which only surfaces it to authorized roles)
     - any signed-in user may WRITE under projects/, with size and
       content-type limits to prevent abuse
   For stricter control, front uploads with a Cloud Function that
   verifies the caller owns the project, or encode developerUid in
   the path and match on it.
   ============================================================ */

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    // limit uploads to reasonable document sizes (25 MB) and common types
    function okFile() {
      return request.resource.size < 25 * 1024 * 1024
        && (
          request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('application/vnd.*')   // office xlsx/docx/pptx
          || request.resource.contentType.matches('text/.*')
          || request.resource.contentType.matches('application/octet-stream')
        );
    }

    match /projects/{projectId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && okFile();
    }

    // deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
