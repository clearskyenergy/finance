rules_version = '2';

/* ============================================================
   ClearSky-OMEGA · Financing Partners Portal
   Firestore security rules  (NAMESPACED collections)
   ------------------------------------------------------------
   This portal shares the clearsky-portal database with other
   ClearSky apps. To avoid collision it uses:
     fin_profiles/{uid}      - this portal's user profiles
     fin_projects/{id}       - this portal's projects (+ offers, inquiries)
     partnerAllowlist/{email} - SHARED existing allowlist (read-only here)

   IMPORTANT: this file is the MERGED ruleset for the whole clearsky-portal
   database. It covers this portal's namespaced collections, the shared
   read-only allowlist, AND the existing ClearSky-OMEGA /projects rules
   (at the bottom). Deploying replaces the entire database's rules, so keep
   every portal's rules in here.
   ============================================================ */

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    /* email-domain org id — used by the existing OMEGA projects rules below */
    function userOrg() {
      return request.auth.token.email.split('@')[1];
    }
    function myProfile() {
      return get(/databases/$(database)/documents/fin_profiles/$(request.auth.uid)).data;
    }
    function myRole() {
      return myProfile().role;
    }
    function isDeveloper() {
      return signedIn() && myRole() == 'developer';
    }
    function isPartner() {
      return signedIn() && myRole() == 'partner';
    }

    /* ---------------- shared partner allowlist (read-only) ----------------
       The app reads partnerAllowlist/{email} during signup to decide if a
       user may hold the partner role. Keep any write rules your other
       portal already defines for this collection; this portal never writes it. */
    match /partnerAllowlist/{email} {
      allow read: if signedIn();
      // writes governed by your admin tooling / other portal rules
    }

    /* ---------------- this portal's user profiles ---------------- */
    match /fin_profiles/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;

      // On create: a user writes only their own profile. Role must be
      // 'developer', OR 'partner' only if their email is on the active
      // partner allowlist. This blocks self-assigning partner access.
      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.role in ['developer', 'partner']
        && (
             request.resource.data.role == 'developer'
             || (
                  exists(/databases/$(database)/documents/partnerAllowlist/$(request.resource.data.emailLower))
                  && get(/databases/$(database)/documents/partnerAllowlist/$(request.resource.data.emailLower)).data.active == true
                  && get(/databases/$(database)/documents/partnerAllowlist/$(request.resource.data.emailLower)).data.role == 'partner'
                )
           );

      // Role can't change after creation.
      allow update: if signedIn() && request.auth.uid == uid
        && request.resource.data.role == resource.data.role;

      allow delete: if false;
    }

    /* ---------------- this portal's projects ---------------- */
    match /fin_projects/{projectId} {

      function isOwner() {
        return signedIn() && resource.data.developerUid == request.auth.uid;
      }
      function isAwardee() {
        return signedIn() && resource.data.awardedTo == request.auth.uid;
      }
      function isBrowsable() {
        return resource.data.status == 'open' || resource.data.status == 'offered';
      }

      // READ: owner always; partner if browsable OR awarded to them.
      allow read: if isOwner()
                  || (isPartner() && (isBrowsable() || isAwardee()));

      // CREATE: developers only, own project, starting open + unawarded.
      allow create: if isDeveloper()
                    && request.resource.data.developerUid == request.auth.uid
                    && request.resource.data.status == 'open'
                    && request.resource.data.awardedTo == null;

      // UPDATE: only the owner-developer edits the project doc (incl. the
      // award transition when they accept an offer). developerUid is fixed.
      allow update: if isOwner()
                    && request.resource.data.developerUid == resource.data.developerUid;

      allow delete: if isOwner() && resource.data.status != 'awarded';

      /* ------------ offers ------------ */
      match /offers/{offerId} {
        function parent() {
          return get(/databases/$(database)/documents/fin_projects/$(projectId)).data;
        }
        function parentOwner() {
          return parent().developerUid == request.auth.uid;
        }

        // developer-owner reads all offers; a partner reads only their own.
        allow read: if signedIn() && (
                       parentOwner() ||
                       (isPartner() && offerId == request.auth.uid)
                    );

        // partner writes only their own offer (offerId == uid) pre-award.
        allow create, update: if isPartner()
                    && offerId == request.auth.uid
                    && request.resource.data.partnerUid == request.auth.uid
                    && parent().status != 'awarded';

        // owner accepts/rejects; partner may recall their own.
        allow update: if parentOwner()
                    || (isPartner() && offerId == request.auth.uid);

        allow delete: if false;
      }

      /* ------------ inquiries ------------ */
      match /inquiries/{msgId} {
        function parent() {
          return get(/databases/$(database)/documents/fin_projects/$(projectId)).data;
        }
        function parentOwner() {
          return parent().developerUid == request.auth.uid;
        }
        function parentAwardee() {
          return parent().awardedTo == request.auth.uid;
        }
        function parentBrowsable() {
          return parent().status == 'open' || parent().status == 'offered';
        }

        allow read: if signedIn() && (
                       parentOwner() ||
                       (isPartner() && (parentBrowsable() || parentAwardee()))
                    );

        allow create: if signedIn()
                    && request.resource.data.authorUid == request.auth.uid
                    && (
                        parentOwner() ||
                        (isPartner() && (parentBrowsable() || parentAwardee()))
                       );

        allow update, delete: if false;
      }
    }

    /* ============================================================
       OTHER PORTALS' RULES — merged in so this deploy protects them.
       ------------------------------------------------------------
       ClearSky-OMEGA workspace projects: org-scoped by email domain,
       with a legacy uid-only fallback. (userOrg() defined up top.)
       ============================================================ */
    match /projects/{projectId} {
      // Read: org projects OR your own legacy (uid-only) projects
      allow read: if request.auth != null
                  && (
                    resource.data.orgId == userOrg()
                    || resource.data.uid == request.auth.uid
                  );
      allow create: if request.auth != null
                    && request.resource.data.orgId == userOrg();
      // UPDATE: you own the doc (by org or legacy uid), and the result is
      // still stamped with your org.
      allow update: if request.auth != null
                    && (
                      resource.data.orgId == userOrg()
                      || resource.data.uid == request.auth.uid
                    )
                    && request.resource.data.orgId == userOrg();
      // DELETE: you own the doc. No request.resource check on deletes.
      allow delete: if request.auth != null
                    && (
                      resource.data.orgId == userOrg()
                      || resource.data.uid == request.auth.uid
                    );
    }

  }
}
